{
    "name": "quoterer-bot",
    "version": "2.0.1",
    "type": "module",
    "main": "dist/index.mjs",
    "scripts": {
        "dev": "npm run build:external && node dist/index.cjs",
        "start": "node dist/index.cjs",
        "deploy": "esbuild scripts/deploy-to-guild.ts --outfile='./dist/scripts/deploy-to-guild.cjs' --platform=node --bundle --minify --packages=external && node dist/scripts/deploy-to-guild.cjs",
        "build": "esbuild src/index.ts --outfile=dist/index.cjs --platform=node --bundle --minify",
        "build:external": "esbuild src/index.ts --outfile=dist/index.cjs --platform=node --bundle --minify --packages=external",
        "check:lint": "eslint .",
        "check:style": "prettier --check .",
        "check": "npm run check:lint && npm run check:style",
        "format": "eslint --fix . && prettier --write ."
    },
    "keywords": [
        "discord",
        "bot",
        "quote",
        "app",
        "db",
        "database"
    ],
    "contributors": [
        {
            "name": "Traube1000101"
        },
        {
            "name": "Aseraphyss"
        }
    ],
    "license": "ISC",
    "description": "A Discord Bot which sends quotes in a guild and stores them in a database.",
    "dependencies": {
        "discord.js": "^14.25.1",
        "dotenv": "^17.3.1",
        "esbuild": "0.27.3",
        "graphql": "^16.13.1",
        "graphql-request": "^7.4.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
